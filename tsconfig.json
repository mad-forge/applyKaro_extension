{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules",
    "backend"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "compilerOptions": {
    "types": [
      "chrome",
      "node"
    ],
    "paths": {
      "~*": [
        "./src/*"
      ]
    },
    "baseUrl": "."
  }
}
