{
  "name": "interviewmint-job-optimizer-extension",
  "displayName": "InterviewMint Job Optimizer",
  "version": "0.0.1",
  "description": "Track job applications and optimize resumes for ATS with AI.",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "contributors": [
    "louisgv"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "scripting",
      "storage"
    ],
    "host_permissions": [
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*",
      "https://*/*"
    ]
  }
}
